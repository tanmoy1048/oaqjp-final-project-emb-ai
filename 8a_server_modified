"""Flask server for EmotionDetection frontend integration.

This development server exposes an endpoint that calls the local
emotion detection helper and renders the frontend index page.
"""

from typing import Dict

from flask import Flask, request, make_response, jsonify, render_template

# Local import; pylint may not be able to resolve it in some environments
from emotion_detection import emotion_detector  # pylint: disable=import-error


app = Flask(__name__)


@app.route('/emotionDetector', methods=['GET'])
def emotion_detector_api():
    """Accepts JSON {"text": "..."} and returns a plain-text formatted emotion summary.

    Example response (shortened):
    "For the given statement, the system response lists scores and dominant emotion."
    """
    text = request.args.get('text', '')

    try:
        result: Dict[str, float] = emotion_detector(text)
    except Exception as err:  # pylint: disable=broad-except
        return make_response(
            jsonify({'error': 'Failed to analyze text', 'details': str(err)}),
            500,
        )

    # If the detector returned None for dominant_emotion, show a friendly message
    if result.get('dominant_emotion') is None:
        resp = make_response('Invalid text! Please try again!', 200)
        resp.headers['Content-Type'] = 'text/plain; charset=utf-8'
        return resp

    # Format the response string with 9 decimal places for floats
    anger_str = f"'anger': {result.get('anger', 0.0):.9f}"
    disgust_str = f"'disgust': {result.get('disgust', 0.0):.9f}"
    fear_str = f"'fear': {result.get('fear', 0.0):.9f}"
    joy_str = f"'joy': {result.get('joy', 0.0):.9f}"
    sadness_str = f"'sadness': {result.get('sadness', 0.0):.9f}"
    dominant = result.get('dominant_emotion', 'unknown')

    formatted = (
        'For the given statement, the system response is '
        f"{anger_str}, {disgust_str}, {fear_str}, {joy_str} and {sadness_str}. "
        f"The dominant emotion is {dominant}."
    )

    response = make_response(formatted, 200)
    response.headers['Content-Type'] = 'text/plain; charset=utf-8'
    return response


@app.route('/', methods=['GET'])
def index():
    """Render the frontend index page from the templates directory."""
    return render_template('index.html')


if __name__ == '__main__':
    # Run on all interfaces so it can be called from your frontend during development
    app.run(host='0.0.0.0', port=5000, debug=True)
